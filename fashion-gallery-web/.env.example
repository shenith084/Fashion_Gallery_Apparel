# -----------------------------------------------------------------------------
# NEXT.JS & VERCEL CONFIGURATION
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# FIREBASE CONFIGURATION (Public Client Keys)
# Safe to expose in the browser
# -----------------------------------------------------------------------------
NEXT_PUBLIC_FIREBASE_API_KEY=your_api_key_here
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project-id.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=1234567890
NEXT_PUBLIC_FIREBASE_APP_ID=1:1234567890:web:abcdef123456

# -----------------------------------------------------------------------------
# FIREBASE ADMIN SDK (Server Side Only - NEVER EXPOSE)
# Used for custom claims, server actions, and bypassing security rules
# -----------------------------------------------------------------------------
FIREBASE_ADMIN_PROJECT_ID=your-project-id
FIREBASE_ADMIN_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project-id.iam.gserviceaccount.com
# IMPORTANT: In Vercel, enclose the private key in quotes or ensure newlines (\n) are preserved.
FIREBASE_ADMIN_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIEv...your_long_key_here...\n-----END PRIVATE KEY-----\n"

# -----------------------------------------------------------------------------
# CLOUDINARY CONFIGURATION (Media Management)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your_cloud_name
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET=your_upload_preset
CLOUDINARY_API_KEY=your_api_key
# SERVER SIDE ONLY - NEVER EXPOSE
CLOUDINARY_API_SECRET=your_api_secret

# -----------------------------------------------------------------------------
# RESEND CONFIGURATION (Transactional Emails)
# -----------------------------------------------------------------------------
RESEND_API_KEY=re_123456789

# -----------------------------------------------------------------------------
# ANALYTICS & MARKETING PIXELS (Public)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_META_PIXEL_ID=1234567890
NEXT_PUBLIC_TIKTOK_PIXEL_ID=1234567890
