rules_version = '2';
// =====================================================
// FIRESTORE SECURITY RULES
// Fashion Gallery Apparel — My Moon Clothing
// =====================================================

service cloud.firestore {
  match /databases/{database}/documents {

    // ─── HELPER FUNCTIONS ─────────────────────────────────────
    function isAuthenticated() {
      return request.auth != null;
    }

    function isSuperAdmin() {
      // Allow the hardcoded UID or anyone with the 'super_admin' custom claim
      return isAuthenticated() && (request.auth.uid == 'WqO0cTDYVWMHrJh3PsZqB0LL6xj1' || request.auth.token.role == 'super_admin');
    }

    function isAdmin() {
      return isSuperAdmin() || (isAuthenticated() && request.auth.token.role == 'admin');
    }

    function isStaff() {
      return isSuperAdmin() || (isAuthenticated() &&
        (request.auth.token.role == 'admin' || request.auth.token.role == 'staff'));
    }

    function hasPermission(permission) {
      return isAdmin() || (
        isStaff() &&
        get(/databases/$(database)/documents/staff/$(request.auth.uid)).data.permissions[permission] == true
      );
    }

    // ─── PRODUCTS ─────────────────────────────────────────────
    match /products/{productId} {
      // Public can read active products
      allow read: if resource.data.status == 'Active' || isStaff();
      // Only staff with permission can write
      allow create: if hasPermission('product.edit_details');
      allow update: if hasPermission('product.edit_details') || hasPermission('product.edit_stock');
      allow delete: if hasPermission('product.delete');

      // Private financial subcollection — Admin only
      match /private/{document} {
        allow read, write: if isAdmin();
      }
    }

    // ─── CATEGORIES ───────────────────────────────────────────
    match /categories/{categoryId} {
      allow read: if true;           // public
      allow write: if isAdmin();
    }

    // ─── ORDERS ───────────────────────────────────────────────
    match /orders/{orderId} {
      // Orders are written ONLY via Server Actions (never from the client directly)
      // Customers can read their own order by orderNumber lookup
      allow read: if isStaff() || (
        isAuthenticated() && resource.data.customerId == request.auth.uid
      );
      // Guests can create orders directly from the client checkout
      allow create: if request.resource.data.keys().hasAll(['customer', 'items', 'total', 'status']);
      allow update: if hasPermission('order.update_status');
      allow delete: if false;         // soft delete only
    }

    // ─── CUSTOMERS ────────────────────────────────────────────
    match /customers/{customerId} {
      allow read: if isStaff() || request.auth.uid == customerId;
      allow write: if false;          // created via Server Action only
    }

    // ─── WHOLESALE APPLICATIONS ───────────────────────────────
    match /wholesale_applications/{appId} {
      allow read: if isStaff() && hasPermission('wholesale.view');
      allow create: if true; // Public can apply
      allow update, delete: if isStaff() && hasPermission('wholesale.view');
    }

    // ─── INQUIRIES ────────────────────────────────────────────
    match /inquiries/{inquiryId} {
      allow read: if hasPermission('wholesale.view');
      allow create: if true;          // public can submit inquiries
      allow update: if isStaff();
      allow delete: if isAdmin();
    }

    // ─── STAFF ────────────────────────────────────────────────
    match /staff/{staffId} {
      allow read: if isStaff();
      
      // Creating staff is strictly done via Admin SDK (bypasses rules)
      allow create: if false; 
      
      // Updates allowed by admins, but no one can modify a super admin's role except a super admin
      allow update: if isAdmin() && (
        isSuperAdmin() || resource.data.role != 'super_admin'
      );
      
      // Deleting staff requires admin. Super admins cannot be deleted by anyone!
      allow delete: if isAdmin() && resource.data.role != 'super_admin';
    }

    // ─── SETTINGS ─────────────────────────────────────────────
    match /settings/{docId} {
      allow read: if true;            // public readable
      allow write: if (docId == 'business' && isAdmin()) || (docId != 'business' && hasPermission('settings.manage'));
    }

    // ─── ROLES & PERMISSIONS ──────────────────────────────────
    match /roles/{roleId} {
      allow read: if isStaff();
      allow write: if hasPermission('staff.manage');
    }


    // ─── AUDIT LOGS ───────────────────────────────────────────
    match /auditLogs/{logId} {
      allow read: if isAdmin();
      allow create: if isStaff();     // staff/admin can create log entries
      allow update, delete: if false; // audit logs are immutable
    }

    // ─── NOTIFICATIONS ────────────────────────────────────────
    match /notifications/{notificationId} {
      allow read: if isAuthenticated() && (
        resource.data.audience == request.auth.uid ||
        resource.data.audience == request.auth.token.role ||
        isAdmin()
      );
      allow create: if false;         // created server-side only
      allow update: if isAuthenticated() && (
        resource.data.audience == request.auth.uid  // mark as read
      );
      allow delete: if isAdmin();
    }

  }
}
